# Database
DATABASE_URL="file:./dev.db"

# NextAuth
AUTH_SECRET="generate-with: openssl rand -base64 32"
AUTH_URL="http://localhost:3000"

# Notion Integration
# Notion 통합 토큰: https://www.notion.so/my-integrations 에서 생성
NOTION_TOKEN="your-notion-token-here"
# 견적서 Notion 데이터베이스 ID (URL에서 추출)
NOTION_DATABASE_ID=38fb1a00dfa68005988fe56a22070433
# 견적 항목 Notion 데이터베이스 ID
NOTION_ITEM_DATABASE_ID="your-notion-item-database-id"

# 보안: IP 해시화 시 사용할 솔트
IP_HASH_SALT="generate-with: openssl rand -base64 32"
